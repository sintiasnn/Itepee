# Django Secret Key - ganti dengan key random untuk production
# Cara generate: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=django-insecure-dev-key-jangan-dipakai-produksi

# Debug Mode
DEBUG=True

# Allowed hosts (comma separated)
ALLOWED_HOSTS=localhost,127.0.0.1

# Database: biarkan kosong untuk SQLite (default), set ke "mysql" untuk MySQL
# DB_ENGINE=mysql
# DB_NAME=ItepeeDB
# DB_USER=root
# DB_PASSWORD=
# DB_HOST=localhost
# DB_PORT=3306
